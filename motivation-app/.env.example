# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token from https://api.slack.com/apps → OAuth & Permissions
# Scopes needed (bot): channels:history, channels:read, users:read, chat:write
SLACK_BOT_TOKEN=xoxb-...

# Channel to POST motivational messages into (use channel ID like C0123456789)
SLACK_CHANNEL_ID=C0123456789

# Channels to READ context from (comma-separated IDs, leave blank to skip)
SLACK_READ_CHANNEL_IDS=C0123456789,C9876543210

# ── Google (Gmail + Calendar) ─────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# App type: Desktop app. Enable Gmail API + Google Calendar API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth/callback

# ── Granola ───────────────────────────────────────────────────────────────────
# Leave blank to auto-detect at ~/Library/Application Support/Granola/
GRANOLA_DB_PATH=

# ── App settings ─────────────────────────────────────────────────────────────
# Your first name – personalises the message
USER_NAME=

# Cron schedule (default: every 2 hours, 8am-7pm, Mon-Fri)
# Format: second minute hour day-of-month month day-of-week
CRON_SCHEDULE=0 0 8,10,12,14,16,18 * * 1-5
